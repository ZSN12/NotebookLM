# ============================================
# Nootbook - Environment Configuration Example
# Copy this file to .env and fill in your values
# ============================================

# Database (PostgreSQL required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nootbook
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nootbook_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nootbook

# AI API Keys (at least one is required)
DASHSCOPE_API_KEY=your-dashscope-key
QWEN_VL_API_KEY=your-qwen-vl-key
DEEPSEEK_API_KEY=your-deepseek-key

# Optional AI config
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Security (MUST be set in production)
SECRET_KEY=change-this-to-a-32-char-random-string!!!

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Default admin account (only used on first startup)
ADMIN_DEFAULT_EMAIL=admin
ADMIN_DEFAULT_PASSWORD=changeme

# Development only
SKIP_ASR_PRELOAD=0
AGENTS_SYNC=0
